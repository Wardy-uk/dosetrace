{
  "name": "DoseTrace",
  "short_name": "DoseTrace",
  "description": "Lightweight GLP-1 tracker with dose history and estimated medication-level graph.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#f6f0e6",
